# ============================================================
# YouTube AI Automation — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://ytbot:ytbot@localhost:5432/youtube_automation

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Primary AI Endpoint (Router/Proxy — free, high-quality models) ──
PRIMARY_API_BASE=https://your-router9-endpoint.com/v1
PRIMARY_API_KEY=your_router_key_here
PRIMARY_MODEL=gpt-4o

# ── Fallback AI Endpoint (Google AI Studio — free tier) ──────
FALLBACK_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
FALLBACK_API_KEY=AIzaSyYOUR_AISTUDIO_KEY_HERE
FALLBACK_MODEL=gemini-2.5-flash

# ── Telegram Notifications / Remote Control ─────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=your_chat_id_here
PUBLIC_BASE_URL=https://studio.veo3depzai.io.vn
CLOUDFLARE_TUNNEL_TOKEN=

# ── YouTube Data API ────────────────────────────────────────
YOUTUBE_API_KEY=AIzaSyYOUR_YOUTUBE_API_KEY_HERE
YOUTUBE_UPLOAD_ENABLED=false
YOUTUBE_OAUTH_CLIENT_ID=your_google_oauth_client_id
YOUTUBE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
YOUTUBE_OAUTH_CALLBACK_PATH=/api/youtube/oauth/callback
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
YOUTUBE_TOKEN_ENCRYPTION_KEY=your_fernet_key
YOUTUBE_UPLOAD_MAX_ATTEMPTS=5
YOUTUBE_UPLOAD_POLL_SECONDS=5

# ── Image APIs (all free, get keys at their websites) ────────
UNSPLASH_API_KEY=your_unsplash_access_key_here
PEXELS_API_KEY=your_pexels_api_key_here
PIXABAY_API_KEY=your_pixabay_api_key_here

# ── Storage ─────────────────────────────────────────────────
STORAGE_PATH=./output

# ── Production Performance ──────────────────────────────────
# Parallel real-image lookup per video. Use 4 by default; max enforced in code is 8.
REAL_IMAGE_CONCURRENCY=4

# Keep valid cards, replace local failures, and render at the quality threshold.
RESILIENT_CARD_PIPELINE_ENABLED=true
CARD_MINIMUM_RATIO=0.80
CARD_PLANNER_ATTEMPTS=4
CARD_CONTENT_REPAIR_ATTEMPTS=2
CARD_FACT_REPAIR_ATTEMPTS=2
CARD_REPLACEMENT_ATTEMPTS=3
AI_JSON_REPAIR_ATTEMPTS=2
AI_TRANSPORT_ATTEMPTS=3

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
