# ============================================================
# YouTube AI Automation — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://ytbot:ytbot@localhost:5432/youtube_automation

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Primary AI Endpoint (Router/Proxy — free, high-quality models) ──
PRIMARY_API_BASE=https://your-router9-endpoint.com/v1
PRIMARY_API_KEY=your_router_key_here
PRIMARY_MODEL=gpt-4o

# ── Fallback AI Endpoint (Google AI Studio — free tier) ──────
FALLBACK_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
FALLBACK_API_KEY=AIzaSyYOUR_AISTUDIO_KEY_HERE
FALLBACK_MODEL=gemini-2.5-flash

# ── Telegram Notifications / Remote Control ─────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=your_chat_id_here

# ── YouTube Data API ────────────────────────────────────────
YOUTUBE_API_KEY=AIzaSyYOUR_YOUTUBE_API_KEY_HERE

# ── Image APIs (all free, get keys at their websites) ────────
UNSPLASH_API_KEY=your_unsplash_access_key_here
PEXELS_API_KEY=your_pexels_api_key_here
PIXABAY_API_KEY=your_pixabay_api_key_here

# ── Storage ─────────────────────────────────────────────────
STORAGE_PATH=./output

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
