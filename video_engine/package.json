{
  "name": "youtube-ai-video-engine",
  "version": "1.0.0",
  "description": "Remotion-based video engine for YouTube AI Automation",
  "private": true,
  "scripts": {
    "studio": "remotion studio src/index.tsx",
    "render:timeline": "remotion render src/index.tsx TimelineVideo out/timeline.mp4",
